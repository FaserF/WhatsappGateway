{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchDatasources": ["npm"],
      "matchPackageNames": ["@whiskeysockets/baileys"],
      "ignoreUnstable": false
    },
    {
      "matchManagers": ["github-actions"],
      "automerge": true
    }
  ]
}
